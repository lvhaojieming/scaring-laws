#!/usr/bin/env python3
"""
Download a weighted Hugging Face pretraining mix as newline-delimited JSON.

Default dataset:
  balanced_web_edu_mix_10B

Default weights:
  C4: 35%
  FineWeb-Edu: 30%
  SlimPajama: 20%
  OpenWebText2: 10%
  Wikipedia / StackExchange / arXiv: 5% total, split equally

The script writes one JSONL file per source under:
  /datadisk_1/balanced_web_edu_mix_10B/jsonl/

Each output line is:
  {"text": "...", "source": "...", "source_repo": "..."}

The target is approximate because it estimates tokens from characters unless a
dataset exposes a token_count column.
"""

from __future__ import annotations

import argparse
import hashlib
import importlib
import json
import os
import random
import sys
import tarfile
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Iterable
from urllib.parse import quote


HF_DATASET_BASE = "https://huggingface.co/datasets"
DEFAULT_OUTPUT_DIR = Path("/datadisk_1/balanced_web_edu_mix_10B")


@dataclass(frozen=True)
class Source:
    name: str
    weight: float
    repo: str
    file_globs: tuple[str, ...]
    loader: str
    text_fields: tuple[str, ...]
    max_files: int | None = None
    shuffle_files: bool = True

    @property
    def url(self) -> str:
        return f"{HF_DATASET_BASE}/{self.repo}"


SOURCES: tuple[Source, ...] = (
    Source(
        name="c4",
        weight=0.35,
        repo="allenai/c4",
        file_globs=("en/c4-train.*.json.gz",),
        loader="json",
        text_fields=("text",),
    ),
    Source(
        name="fineweb_edu",
        weight=0.30,
        repo="HuggingFaceFW/fineweb-edu",
        file_globs=("sample/10BT/*.parquet",),
        loader="parquet",
        text_fields=("text",),
    ),
    Source(
        name="slimpajama",
        weight=0.20,
        repo="gmongaras/SlimPajama-627B_Reupload",
        file_globs=("data/train-*.parquet",),
        loader="parquet",
